{
  "name": "@quanghuy1242/idco-reader",
  "version": "0.1.25",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./islands": {
      "types": "./dist/islands/index.d.ts",
      "default": "./dist/islands/index.js"
    },
    "./islands/live-code": {
      "types": "./dist/islands/live-code.d.ts",
      "default": "./dist/islands/live-code.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/gen-api-map.mjs .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@quanghuy1242/idco-lib": "workspace:^"
  },
  "peerDependencies": {
    "@quanghuy1242/idco-ui": "workspace:^",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@quanghuy1242/idco-ui": {
      "optional": true
    }
  }
}
