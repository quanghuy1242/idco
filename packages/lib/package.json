{
  "name": "@quanghuy1242/idco-lib",
  "version": "0.1.25",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "jose": "^6.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/gen-api-map.mjs .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
