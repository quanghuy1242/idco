{
  "name": "@quanghuy1242/idco-editor",
  "version": "0.1.25",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/fix-worker-specifier.mjs . && cp styles.css dist/styles.css && node ../../scripts/gen-api-map.mjs .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@quanghuy1242/idco-lib": "workspace:^",
    "@quanghuy1242/idco-reader": "workspace:^",
    "@quanghuy1242/idco-ui": "workspace:^",
    "markdown-it": "^14.2.0",
    "markdown-it-mark": "^4.0.0",
    "react-aria-components": "1.17.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
