{
  "name": "@quanghuy1242/idco-ui",
  "version": "0.1.5",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "react-aria": "3.48.0",
    "react-aria-components": "1.17.0",
    "react-stately": "3.46.0",
    "lucide-react": "1.16.0"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
