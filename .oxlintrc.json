{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "vitest", "import", "promise"],
  "jsPlugins": ["./scripts/oxlint-js-plugins/architecture.js"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "settings": {
    "vitest": {
      "testPattern": ["tests/**/*.test.ts", "tests/**/*.test.tsx"]
    }
  },
  "rules": {
    "no-console": "error",
    "eqeqeq": "error",
    "import/no-cycle": "error",
    "import/no-default-export": "off",
    "typescript/no-explicit-any": "error",
    "unicorn/no-array-sort": "off",
    "architecture/editor-no-direct-update-listener": "error",
    "architecture/engine-core-no-framework": "error",
    "architecture/idco-package-boundary": "error",
    "architecture/no-inline-record-guard": "error",
    "architecture/reader-l1-purity": "error",
    "architecture/ui-no-side-effect-css": "error",
    "architecture/ui-no-native-dialog": "error",
    "architecture/ui-no-neutral-button-class": "error"
  },
  "overrides": [
    {
      "files": ["packages/editor/src/vendor/editcontext-polyfill/**/*.ts"],
      "rules": {
        "no-underscore-dangle": "off",
        "typescript/no-unsafe-declaration-merging": "off"
      }
    },
    {
      "files": ["tests/**/*.ts", "tests/**/*.tsx"],
      "rules": {
        "no-console": "off",
        "no-await-in-loop": "off"
      }
    }
  ],
  "ignorePatterns": ["node_modules", "dist", "coverage", ".wrangler", ".ladle/build"],
  "env": {
    "es2022": true,
    "browser": true,
    "node": true
  }
}
