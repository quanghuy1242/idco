{
  "compilerOptions": {
    "target": "ES2025",
    "lib": ["ES2025", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@idco/ui": ["./packages/ui/src/index.ts"],
      "@quanghuy1242/idco-ui": ["./packages/ui/src/index.ts"],
      "@idco/lib": ["./packages/lib/src/index.ts"],
      "@quanghuy1242/idco-lib": ["./packages/lib/src/index.ts"],
      "@idco/reader": ["./packages/reader/src/index.ts"],
      "@quanghuy1242/idco-reader": ["./packages/reader/src/index.ts"],
      "@idco/reader/islands": ["./packages/reader/src/islands/index.ts"],
      "@quanghuy1242/idco-reader/islands": [
        "./packages/reader/src/islands/index.ts"
      ],
      "@idco/editor": ["./packages/editor/src/index.ts"],
      "@quanghuy1242/idco-editor": ["./packages/editor/src/index.ts"],
      "@idco/editor-legacy": ["./packages/editor-legacy/src/index.ts"],
      "@quanghuy1242/idco-editor-legacy": [
        "./packages/editor-legacy/src/index.ts"
      ]
    }
  },
  "include": ["packages", "tests", ".ladle/mocks", "vitest.config.ts"]
}
